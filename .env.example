# Host port for the board
DASHBOARD_PORT=8080

# Hono BFF on shared network `boontar-live-dashboard` (create once):
#   docker network create boontar-live-dashboard
#
# host:port as seen FROM this container:
#   shared network alias:  backend:3000
#   container name:        boontar-live-dashboard-backend:3000
#   host-published port:   host.docker.internal:3000
BACKEND_HOST=backend:3000

# Baked into JS at image build — rebuild after change
VITE_PUSHER_APP_KEY=
VITE_PUSHER_APP_CLUSTER=ap3
